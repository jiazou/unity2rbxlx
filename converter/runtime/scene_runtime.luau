-- scene_runtime: PR4 generic host runtime for the scene-runtime contract.
--
-- Consumes the per-place ``scene_runtime_plan`` ModuleScript embedded
-- by ``write_output`` (Piece 5) and exposes the host surface every
-- contract-compliant MonoBehaviour module depends on (Pieces 1 + 6).
--
-- Architecture (six pieces):
--   Pieces 1-4 (transpiler contract, planner, ID stamping, packaging)
--   land in PR1-PR3b and produce the input artifacts this engine reads.
--   PR4 (this file) realizes Pieces 5 + 6: instantiate every
--   runtime-bearing MonoBehaviour, wire serialized references, run the
--   lifecycle, and provide the runtime object-model services.
--
-- Services (Piece 6):
--   * Component registry  -- ``self:GetComponent(name)`` -> peer module
--     or Roblox built-in component fallback (``Rigidbody`` / ``Button`` /
--     ``Collider`` / ``AudioSource`` / ``Animator``).
--   * Global lookup       -- ``host.findObjectOfType`` /
--     ``findGameObject`` / ``findGameObjectsWithTag`` (sees inactive).
--   * Lifecycle-scoped scheduler -- ``host.invoke`` /
--     ``invokeRepeating`` / ``cancelInvoke`` / ``startCoroutine``;
--     cancels every per-component task on ``OnDestroy``.
--   * Lifecycle-scoped event wiring -- ``host.connect(self, signal, fn)``;
--     dispatch gated on ``active && enabled`` (Unity-message-callback
--     semantics; rule (f) compliance partner).
--   * Dynamic component creation -- ``host.addComponent(go, scriptId,
--     config?)``; instantiate at runtime, register, run
--     ``Awake -> OnEnable -> Start``.
--   * Prefab instantiation -- ``host.instantiatePrefab(prefab_id,
--     parent, cframe, externalRefs?)``; clones a template and drives
--     intra-prefab lifecycle.
--   * Recursive teardown -- ``host.destroy(target)``; DFS deepest-first
--     ``OnDisable`` -> ``OnDestroy``, idempotent, registry-aware.
--   * Cross-domain reference policy (v1) -- the host injects ``nil`` and
--     logs a structured warning when a serialized ref crosses the
--     ``client``/``server`` boundary (the conversion-time edge report
--     surfaces the same edges in ``UNCONVERTED.md``).
--
-- Test harness:
--   The module's surface is constructed by ``SceneRuntime.new(services,
--   plan)`` so tests can inject mock Roblox primitives (``task``,
--   ``Instance``, signal Connect/Disconnect, etc.). Production
--   entrypoints (SceneRuntimeClient/Server, generated by
--   ``write_output``) supply the real Roblox services.

local SceneRuntime = {}
SceneRuntime.__index = SceneRuntime

-- ---------------------------------------------------------------------
-- Service surface accepted by ``SceneRuntime.new``.
--
-- A *services* table bundles every Roblox primitive the engine touches.
-- The entrypoint scripts inject the real implementations; the test
-- harness injects controllable stubs.
--
-- Required fields:
--   task           -- ``{ spawn, defer, delay, wait }``
--   warn           -- ``function(...)`` (defaults to global ``warn``)
--   resolveModule  -- ``function(script_id, module_path) -> module``;
--                     loads a transpiled MonoBehaviour ModuleScript by
--                     plan-row id and resolved DataModel path.
--   workspaceFind  -- ``function(scene_runtime_id) -> Instance | nil``;
--                     looks an Instance up by its ``_SceneRuntimeId``
--                     attribute. Implementation typically caches a
--                     workspace + UI scan keyed by that attribute.
--   findFirstChildWhichIsA -- ``function(instance, class_name) ->
--                     Instance | nil``; used by GetComponent fallback.
--   heartbeat      -- a Roblox-shaped signal (``signal:Connect(fn)``
--                     returns a connection). Drives Update / LateUpdate.
--   fixedStep      -- number (seconds) for FixedUpdate accumulator
--                     (Unity's default is 0.02).
--   now            -- ``function() -> number`` (monotonic seconds).
-- ---------------------------------------------------------------------

-- ---------------------------------------------------------------------
-- Constructor
-- ---------------------------------------------------------------------

function SceneRuntime.new(services, plan)
	assert(type(services) == "table", "SceneRuntime.new: services required")
	assert(type(plan) == "table", "SceneRuntime.new: plan required")

	local self = setmetatable({}, SceneRuntime)
	self._services = services
	self._plan = plan
	self._warn = services.warn or function(...) end

	-- Live registry: ``<game_object_id, list[component_instance]>``.
	-- Mutated by ``instantiatePrefab`` / ``addComponent`` / ``destroy``.
	self._componentsByGameObject = {}

	-- Reverse map: component instance -> {scriptId, gameObjectId,
	-- ownerKind, ownerRef}. Lets the scheduler/event-wiring services
	-- look up provenance for a ``self`` without forcing each
	-- MonoBehaviour to carry the metadata.
	self._meta = {}

	-- Per-component task table for the lifecycle-scoped scheduler.
	-- ``_tasks[componentInstance] = { handle1, handle2, ... }``;
	-- ``OnDestroy`` cancels every handle.
	self._tasks = {}

	-- Per-component subscription table for ``host.connect``:
	-- ``_subs[componentInstance] = { {signal=, fn=, conn=, armed=}, ... }``.
	-- ``OnDestroy`` disconnects them all; gate transitions rearm them.
	self._subs = {}

	-- Per-game-object dormant-active flag (the ``setActive`` toggle the
	-- host owns). Combined with per-component ``enabled`` to derive the
	-- ``active && enabled`` dispatch gate.
	self._goActive = {}

	-- Global lookups for ``findObjectOfType`` / ``findGameObject`` /
	-- ``findGameObjectsWithTag``. Built once at start, updated on
	-- ``instantiatePrefab`` / ``addComponent`` / ``destroy``.
	self._byClass = {}      -- scriptStem -> list[component]
	self._byName = {}       -- gameObjectName -> list[component]
	self._byTag = {}        -- tag -> list[component]

	-- Track which prefab instances we've spawned, keyed by clone
	-- Instance (so ``destroy(clone)`` can find the descendants to tear
	-- down without re-walking).
	self._prefabClones = {}

	-- FixedUpdate accumulator.
	self._fixedStep = services.fixedStep or (1 / 50)
	self._fixedAccum = 0

	-- Track per-component (component, gameObjectId) destroy status so
	-- ``host.destroy(parent)`` is idempotent.
	self._destroyed = {}

	return self
end

-- ---------------------------------------------------------------------
-- Registry helpers
-- ---------------------------------------------------------------------

function SceneRuntime:_register(componentInstance, meta)
	local goId = meta.gameObjectId
	local bucket = self._componentsByGameObject[goId]
	if not bucket then
		bucket = {}
		self._componentsByGameObject[goId] = bucket
	end
	table.insert(bucket, componentInstance)
	self._meta[componentInstance] = meta

	local stem = meta.stem or meta.scriptId or ""
	if stem ~= "" then
		local list = self._byClass[stem]
		if not list then list = {}; self._byClass[stem] = list end
		table.insert(list, componentInstance)
	end
	local name = meta.gameObjectName or ""
	if name ~= "" then
		local list = self._byName[name]
		if not list then list = {}; self._byName[name] = list end
		table.insert(list, componentInstance)
	end
	local tag = meta.tag or ""
	if tag ~= "" then
		local list = self._byTag[tag]
		if not list then list = {}; self._byTag[tag] = list end
		table.insert(list, componentInstance)
	end
end

function SceneRuntime:_unregister(componentInstance)
	local meta = self._meta[componentInstance]
	if not meta then return end
	local function rip(t, key)
		local list = t[key]
		if not list then return end
		for i = #list, 1, -1 do
			if list[i] == componentInstance then
				table.remove(list, i)
			end
		end
	end
	rip(self._componentsByGameObject, meta.gameObjectId)
	rip(self._byClass, meta.stem or "")
	rip(self._byName, meta.gameObjectName or "")
	rip(self._byTag, meta.tag or "")
	self._meta[componentInstance] = nil
end

-- ---------------------------------------------------------------------
-- Host surface bound onto each component as ``self.host``
-- ---------------------------------------------------------------------

function SceneRuntime:_makeHostSurface()
	-- Capture ``self`` (the SceneRuntime instance) once; every method
	-- below is dispatched as ``host.X(...)``, NOT ``host:X(...)``, per
	-- the design doc (Piece 1 lists them all as dotted calls).
	local engine = self
	return {
		instantiatePrefab = function(prefab_id, parent, cframe, externalRefs)
			return engine:instantiatePrefab(prefab_id, parent, cframe, externalRefs)
		end,
		addComponent = function(go, scriptId, config)
			return engine:addComponent(go, scriptId, config)
		end,
		destroy = function(target)
			return engine:destroy(target)
		end,
		setActive = function(go, bool)
			return engine:setActive(go, bool)
		end,
		findObjectOfType = function(name) return engine:findObjectOfType(name) end,
		findGameObject = function(name) return engine:findGameObject(name) end,
		findGameObjectsWithTag = function(tag) return engine:findGameObjectsWithTag(tag) end,
		invoke = function(comp, method, delay)
			return engine:invoke(comp, method, delay)
		end,
		invokeRepeating = function(comp, method, delay, every)
			return engine:invokeRepeating(comp, method, delay, every)
		end,
		cancelInvoke = function(comp, method)
			return engine:cancelInvoke(comp, method)
		end,
		startCoroutine = function(comp, fn)
			return engine:startCoroutine(comp, fn)
		end,
		connect = function(comp, signal, fn)
			return engine:connect(comp, signal, fn)
		end,
	}
end

-- ---------------------------------------------------------------------
-- Instance construction
-- ---------------------------------------------------------------------

function SceneRuntime:_buildComponent(scriptId, gameObjectInstance, gameObjectId,
                                       gameObjectName, config, ownerKind, ownerRef)
	local moduleRow = (self._plan.modules or {})[scriptId]
	if not moduleRow then
		self._warn(string.format(
			"[scene_runtime] unknown script_id %q; skipping instance",
			tostring(scriptId)))
		return nil
	end
	local module_path = moduleRow.module_path
	local module_table = self._services.resolveModule(scriptId, module_path)
	if type(module_table) ~= "table" then
		self._warn(string.format(
			"[scene_runtime] module %s (path=%s) did not return a table",
			tostring(scriptId), tostring(module_path)))
		return nil
	end
	if type(module_table.new) ~= "function" then
		self._warn(string.format(
			"[scene_runtime] module %s missing new(config) constructor",
			tostring(scriptId)))
		return nil
	end
	local ok, instance = pcall(module_table.new, config or {})
	if not ok then
		self._warn(string.format(
			"[scene_runtime] %s.new threw: %s", tostring(scriptId), tostring(instance)))
		return nil
	end
	if type(instance) ~= "table" then
		self._warn(string.format(
			"[scene_runtime] %s.new returned non-table", tostring(scriptId)))
		return nil
	end
	-- Stash the class table so GetComponent / addComponent can identify
	-- the type without re-resolving the module.
	self:_register(instance, {
		scriptId = scriptId,
		stem = moduleRow.stem or scriptId,
		gameObjectId = gameObjectId,
		gameObjectName = gameObjectName,
		ownerKind = ownerKind,
		ownerRef = ownerRef,
		classTable = module_table,
		moduleRow = moduleRow,
		domain = moduleRow.domain,
		awakeCalled = false,
		startCalled = false,
		enableCalled = false,
		disableCalled = false,
	})
	return instance
end

function SceneRuntime:_injectHostSurface(instance, gameObjectInstance, gameObjectId)
	-- Surface bound BEFORE Awake, AFTER all new() per the design doc
	-- (lifecycle order steps 1->2->3). Constructor-purity rule (e) makes
	-- it safe to defer host wiring until after every new() returns.
	instance.gameObject = gameObjectInstance
	instance.transform = gameObjectInstance
	instance.instance = gameObjectInstance
	-- ``self.enabled`` is a per-component flag. Writes are intercepted
	-- via a metatable proxy so OnEnable/OnDisable fire on transitions.
	-- We track the underlying value in _meta so the metatable
	-- intercepts can do the gate work without a global key collision.
	local meta = self._meta[instance]
	meta.enabled = true   -- default; planner instance row may override
	meta.activeSelf = true
	instance.host = self:_makeHostSurface()

	-- Install a GetComponent(name) method on the instance. Resolution
	-- order: peer MonoBehaviour by stem -> Roblox built-in via
	-- ``findFirstChildWhichIsA`` on the GameObject. Built-in fallback
	-- preserves the design doc's "search by Roblox class" behaviour for
	-- ``Rigidbody``/``Collider``/``AudioSource``/``Animator``.
	local engine = self
	instance.GetComponent = function(_, name)
		-- Peer-component lookup first.
		local list = engine._componentsByGameObject[gameObjectId]
		if list then
			for _, comp in ipairs(list) do
				local m = engine._meta[comp]
				if m and (m.stem == name or m.scriptId == name) then
					return comp
				end
			end
		end
		-- Roblox built-in fallback.
		if engine._services.findFirstChildWhichIsA then
			return engine._services.findFirstChildWhichIsA(gameObjectInstance, name)
		end
		return nil
	end
end

-- ---------------------------------------------------------------------
-- Reference wiring
-- ---------------------------------------------------------------------

function SceneRuntime:_resolveReferenceTarget(refRow, componentByInstanceId)
	local target_kind = refRow.target_kind
	local target_ref = refRow.target_ref
	if target_kind == "component" then
		return componentByInstanceId[target_ref]
	elseif target_kind == "gameobject" then
		-- Resolve to the Roblox Instance via _SceneRuntimeId attribute.
		return self._services.workspaceFind(target_ref)
	elseif target_kind == "prefab" then
		-- The host injects the stable prefab_id; modules pass it to
		-- ``instantiatePrefab``.
		return target_ref
	elseif target_kind == "scriptable_object" then
		-- The SO module table; the services layer is expected to
		-- ``require`` it during resolveModule fallthrough.
		return self._services.resolveModule(target_ref, target_ref)
	elseif target_kind == "asset" then
		return target_ref   -- ``rbxassetid://...`` string
	end
	return nil
end

function SceneRuntime:_assignFieldOnComponent(instance, field, index, value)
	if index == nil or index == 0 then
		instance[field] = value
		return
	end
	local arr = instance[field]
	if type(arr) ~= "table" then
		arr = {}
		instance[field] = arr
	end
	-- 1-based array per Lua convention; planner emits 0-based indexes
	-- (Unity convention). +1 to bridge.
	arr[index + 1] = value
end

function SceneRuntime:_wireReferences(refs, componentByInstanceId, crossDomainEdges)
	for _, ref in ipairs(refs) do
		local sourceComp = componentByInstanceId[ref["from"]]
		if sourceComp ~= nil then
			local target = self:_resolveReferenceTarget(ref, componentByInstanceId)
			-- Cross-domain policy: if both source and target are
			-- modules with assigned domains and they differ, inject
			-- ``nil`` and surface the edge.
			if ref.target_kind == "component" and target ~= nil then
				local srcMeta = self._meta[sourceComp]
				local tgtMeta = self._meta[target]
				if srcMeta and tgtMeta
				   and srcMeta.domain and tgtMeta.domain
				   and srcMeta.domain ~= "legacy"
				   and tgtMeta.domain ~= "legacy"
				   and srcMeta.domain ~= tgtMeta.domain then
					self._warn(string.format(
						"[scene_runtime] cross-domain ref %s(%s).%s -> %s(%s) -> injecting nil",
						srcMeta.scriptId, srcMeta.domain, ref.field,
						tgtMeta.scriptId, tgtMeta.domain))
					target = nil
					if crossDomainEdges then
						table.insert(crossDomainEdges, {
							from_script = srcMeta.scriptId,
							to_script = tgtMeta.scriptId,
							field = ref.field,
							from_domain = srcMeta.domain,
							to_domain = tgtMeta.domain,
						})
					end
				end
			end
			self:_assignFieldOnComponent(sourceComp, ref.field, ref.index, target)
		end
	end
end

-- ---------------------------------------------------------------------
-- Lifecycle (deterministic order from the design doc)
-- ---------------------------------------------------------------------

local function _safeCall(fn, ...)
	if type(fn) ~= "function" then return end
	local ok, err = pcall(fn, ...)
	if not ok then return false, err end
	return true
end

function SceneRuntime:_callMethod(instance, name, ...)
	local class = self._meta[instance].classTable
	local fn = class and class[name]
	if type(fn) == "function" then
		local ok, err = pcall(fn, instance, ...)
		if not ok then
			self._warn(string.format(
				"[scene_runtime] %s.%s threw: %s",
				tostring(self._meta[instance].scriptId), name, tostring(err)))
		end
	end
end

function SceneRuntime:_runAwakeEnableStart(instances)
	-- Step 3: Awake (in lifecycle_order; constructors already ran in
	-- step 1 + refs were wired in step 2).
	for _, comp in ipairs(instances) do
		local m = self._meta[comp]
		if m and not m.awakeCalled then
			m.awakeCalled = true
			self:_callMethod(comp, "Awake")
		end
	end
	-- Step 4: OnEnable (only active + enabled).
	for _, comp in ipairs(instances) do
		local m = self._meta[comp]
		if m and m.activeSelf and m.enabled and not m.enableCalled then
			m.enableCalled = true
			m.disableCalled = false
			-- Rearm any host.connect subscriptions for this comp.
			self:_rearmSubs(comp)
			self:_callMethod(comp, "OnEnable")
		end
	end
	-- Step 5: Start on next tick.
	local engine = self
	self._services.task.defer(function()
		for _, comp in ipairs(instances) do
			local m = engine._meta[comp]
			if m and not m.startCalled and m.activeSelf and m.enabled then
				m.startCalled = true
				engine:_callMethod(comp, "Start")
			end
		end
	end)
end

-- ---------------------------------------------------------------------
-- Lifecycle-scoped event wiring (host.connect)
-- ---------------------------------------------------------------------

function SceneRuntime:_isGateOpen(comp)
	local m = self._meta[comp]
	if not m then return false end
	return m.activeSelf and m.enabled
end

function SceneRuntime:_rearmSubs(comp)
	local subs = self._subs[comp]
	if not subs then return end
	for _, sub in ipairs(subs) do
		if sub.conn == nil and self:_isGateOpen(comp) then
			-- ``signal:Connect`` per Roblox API.
			sub.conn = sub.signal:Connect(function(...)
				if self:_isGateOpen(comp) then
					sub.fn(...)
				end
			end)
		end
	end
end

function SceneRuntime:_disarmSubs(comp)
	local subs = self._subs[comp]
	if not subs then return end
	for _, sub in ipairs(subs) do
		if sub.conn then
			sub.conn:Disconnect()
			sub.conn = nil
		end
	end
end

function SceneRuntime:connect(comp, signal, fn)
	assert(type(fn) == "function", "host.connect: fn must be function")
	assert(signal ~= nil, "host.connect: signal required")
	local list = self._subs[comp]
	if not list then list = {}; self._subs[comp] = list end
	local entry = { signal = signal, fn = fn, conn = nil }
	table.insert(list, entry)
	if self:_isGateOpen(comp) then
		entry.conn = signal:Connect(function(...)
			if self:_isGateOpen(comp) then
				fn(...)
			end
		end)
	end
	-- Return a handle the caller can ignore. Disconnect is owned by
	-- the engine; raw Disconnect would desync the subs table.
	return entry
end

-- ---------------------------------------------------------------------
-- Lifecycle-scoped scheduler
-- ---------------------------------------------------------------------

function SceneRuntime:_trackTask(comp, handle)
	local list = self._tasks[comp]
	if not list then list = {}; self._tasks[comp] = list end
	table.insert(list, handle)
end

function SceneRuntime:_cancelAllTasks(comp)
	local list = self._tasks[comp]
	if not list then return end
	for _, handle in ipairs(list) do
		-- task.cancel exists in Roblox's task lib; in the harness the
		-- handle can be a sentinel that the stub checks.
		if self._services.task.cancel then
			pcall(self._services.task.cancel, handle)
		end
	end
	self._tasks[comp] = nil
end

function SceneRuntime:invoke(comp, method, delay)
	local engine = self
	local handle
	handle = self._services.task.delay(delay, function()
		if engine._destroyed[comp] then return end
		local m = engine._meta[comp]
		if not m then return end
		local fn = (m.classTable or {})[method]
		if type(fn) == "function" then
			pcall(fn, comp)
		end
	end)
	self:_trackTask(comp, handle)
	-- Stash the method label so ``cancelInvoke`` can target by method.
	self._tasks[comp][#self._tasks[comp]] = {handle = handle, method = method}
	return handle
end

function SceneRuntime:invokeRepeating(comp, method, delay, every)
	local engine = self
	local handle
	handle = self._services.task.delay(delay, function()
		while not engine._destroyed[comp] do
			local m = engine._meta[comp]
			if not m then return end
			local fn = (m.classTable or {})[method]
			if type(fn) == "function" then
				pcall(fn, comp)
			end
			engine._services.task.wait(every)
		end
	end)
	self:_trackTask(comp, handle)
	self._tasks[comp][#self._tasks[comp]] = {handle = handle, method = method, repeating = true}
	return handle
end

function SceneRuntime:cancelInvoke(comp, method)
	local list = self._tasks[comp]
	if not list then return end
	for i = #list, 1, -1 do
		local entry = list[i]
		if (not method) or (type(entry) == "table" and entry.method == method) then
			local h = (type(entry) == "table" and entry.handle) or entry
			if self._services.task.cancel then
				pcall(self._services.task.cancel, h)
			end
			table.remove(list, i)
		end
	end
end

function SceneRuntime:startCoroutine(comp, fn)
	local engine = self
	local handle = self._services.task.spawn(function()
		if engine._destroyed[comp] then return end
		pcall(fn, comp)
	end)
	self:_trackTask(comp, handle)
	return handle
end

-- ---------------------------------------------------------------------
-- Global lookup registry
-- ---------------------------------------------------------------------

function SceneRuntime:findObjectOfType(name)
	local list = self._byClass[name]
	if list and list[1] then return list[1] end
	return nil
end

function SceneRuntime:findGameObject(name)
	local list = self._byName[name]
	if list and list[1] then return list[1] end
	return nil
end

function SceneRuntime:findGameObjectsWithTag(tag)
	local list = self._byTag[tag]
	if not list then return {} end
	-- Return a copy so caller mutation doesn't break the registry.
	local out = {}
	for i, c in ipairs(list) do out[i] = c end
	return out
end

-- ---------------------------------------------------------------------
-- Active / enabled toggles
-- ---------------------------------------------------------------------

function SceneRuntime:setActive(go, bool)
	-- ``go`` may be either a Roblox Instance or a game_object_id string.
	-- We key by id internally; the entrypoint usually passes a stamped
	-- Instance whose ``_SceneRuntimeId`` we can read.
	local goId
	if type(go) == "string" then
		goId = go
	elseif type(go) == "table" and self._services.getInstanceId then
		goId = self._services.getInstanceId(go)
	else
		return
	end
	local list = self._componentsByGameObject[goId]
	if not list then return end
	for _, comp in ipairs(list) do
		local m = self._meta[comp]
		if m then
			local was = m.activeSelf and m.enabled
			m.activeSelf = bool and true or false
			local now = m.activeSelf and m.enabled
			if was and not now then
				m.disableCalled = true
				m.enableCalled = false
				self:_disarmSubs(comp)
				self:_callMethod(comp, "OnDisable")
			elseif (not was) and now then
				m.enableCalled = true
				m.disableCalled = false
				self:_rearmSubs(comp)
				self:_callMethod(comp, "OnEnable")
			end
		end
	end
end

function SceneRuntime:setEnabled(comp, bool)
	local m = self._meta[comp]
	if not m then return end
	local was = m.activeSelf and m.enabled
	m.enabled = bool and true or false
	local now = m.activeSelf and m.enabled
	if was and not now then
		m.disableCalled = true
		m.enableCalled = false
		self:_disarmSubs(comp)
		self:_callMethod(comp, "OnDisable")
	elseif (not was) and now then
		m.enableCalled = true
		m.disableCalled = false
		self:_rearmSubs(comp)
		self:_callMethod(comp, "OnEnable")
	end
end

-- ---------------------------------------------------------------------
-- Recursive destroy
-- ---------------------------------------------------------------------

function SceneRuntime:_destroyComponent(comp)
	if self._destroyed[comp] then return end
	self._destroyed[comp] = true
	self:_cancelAllTasks(comp)
	self:_disarmSubs(comp)
	self._subs[comp] = nil

	local m = self._meta[comp]
	if m then
		-- ``OnDisable``/``OnDestroy`` are guaranteed-once and skipped
		-- if OnEnable never ran.
		if m.enableCalled and not m.disableCalled then
			m.disableCalled = true
			self:_callMethod(comp, "OnDisable")
		end
		if m.awakeCalled then
			self:_callMethod(comp, "OnDestroy")
		end
	end
	self:_unregister(comp)
end

function SceneRuntime:destroy(target)
	-- DFS: collect components in the subtree by game-object id, walk
	-- deepest-first.
	-- Two input shapes:
	--   - Roblox Instance: collect IDs via _SceneRuntimeId attribute.
	--   - Component instance directly.
	if self._meta[target] then
		-- Single component case.
		self:_destroyComponent(target)
		return
	end
	if type(target) ~= "table" then return end
	-- Walk the Roblox instance tree deepest-first via the services.
	if self._services.collectDescendantIds then
		local ids = self._services.collectDescendantIds(target)
		-- ids is a list of game_object_id strings, deepest first.
		for _, goId in ipairs(ids) do
			local comps = self._componentsByGameObject[goId]
			if comps then
				-- Iterate over a snapshot since _destroyComponent
				-- unregisters from the same table.
				local snap = {}
				for i, c in ipairs(comps) do snap[i] = c end
				for _, comp in ipairs(snap) do
					self:_destroyComponent(comp)
				end
			end
		end
	end
	-- Track the prefab clone so a subsequent destroy() is idempotent.
	self._prefabClones[target] = nil
	if self._services.destroyInstance then
		pcall(self._services.destroyInstance, target)
	end
end

-- ---------------------------------------------------------------------
-- Dynamic component creation
-- ---------------------------------------------------------------------

function SceneRuntime:addComponent(go, scriptId, config)
	local goId
	local goName = ""
	if type(go) == "string" then
		goId = go
	elseif type(go) == "table" then
		if self._services.getInstanceId then
			goId = self._services.getInstanceId(go)
		end
		goName = (type(go) == "table" and go.Name) or ""
	end
	if not goId then return nil end
	local comp = self:_buildComponent(scriptId, go, goId, goName, config, "runtime", "")
	if not comp then return nil end
	self:_injectHostSurface(comp, go, goId)
	-- Single-instance variants of the lifecycle.
	self:_runAwakeEnableStart({comp})
	return comp
end

-- ---------------------------------------------------------------------
-- Prefab instantiation
-- ---------------------------------------------------------------------

function SceneRuntime:instantiatePrefab(prefab_id, parent, cframe, externalRefs)
	local prefab = (self._plan.prefabs or {})[prefab_id]
	if not prefab then
		self._warn(string.format(
			"[scene_runtime] instantiatePrefab: no prefab subplan for %q",
			tostring(prefab_id)))
		return nil
	end
	-- Clone the template via services (production: clone the
	-- ReplicatedStorage template; harness: synthesize a fake instance).
	local clone = self._services.clonePrefabTemplate(prefab_id, parent, cframe)
	if not clone then return nil end
	self._prefabClones[clone] = prefab_id

	-- Build a per-instance map for the prefab subplan; references are
	-- prefab-local so the same logic applies as for scenes.
	local componentByInstanceId = {}
	local componentList = {}
	for _, inst in ipairs(prefab.instances or {}) do
		-- Map intra-prefab game_object_id to the actual Roblox child via
		-- the services helper (production: walk by _SceneRuntimeId
		-- under the clone; harness: pass-through).
		local goInst = self._services.resolveCloneChild(clone, inst.game_object_id)
		local comp = self:_buildComponent(
			inst.script_id, goInst, inst.game_object_id,
			(goInst and goInst.Name) or "", inst.config or {},
			"prefab", prefab_id)
		if comp then
			componentByInstanceId[inst.instance_id] = comp
			table.insert(componentList, comp)
		end
	end
	for _, comp in ipairs(componentList) do
		local m = self._meta[comp]
		self:_injectHostSurface(comp, m and m.gameObjectInstance, m and m.gameObjectId)
	end
	self:_wireReferences(prefab.references or {}, componentByInstanceId, nil)
	-- Caller-supplied externals override matching wired refs.
	if type(externalRefs) == "table" then
		for instId, fields in pairs(externalRefs) do
			local comp = componentByInstanceId[instId]
			if comp and type(fields) == "table" then
				for k, v in pairs(fields) do
					comp[k] = v
				end
			end
		end
	end
	self:_runAwakeEnableStart(componentList)
	return clone
end

-- ---------------------------------------------------------------------
-- Boot: read the plan, drive every scene's lifecycle
-- ---------------------------------------------------------------------

function SceneRuntime:start(domainFilter)
	-- ``domainFilter`` filters modules by ``domain == filter``; the
	-- entrypoint passes ``"client"`` or ``"server"``. ``nil`` instantiates
	-- everything (used by the harness).
	local crossDomainEdges = {}

	-- Phase 0: collect runtime-bearing module ids for this side.
	local includeScriptId = {}
	for sid, row in pairs(self._plan.modules or {}) do
		if row.runtime_bearing and row.domain ~= "legacy" then
			if (domainFilter == nil) or (row.domain == domainFilter) then
				includeScriptId[sid] = true
			end
		end
	end

	local sceneOrder = {}
	for sceneKey, _ in pairs(self._plan.scenes or {}) do
		table.insert(sceneOrder, sceneKey)
	end
	table.sort(sceneOrder)   -- determinism

	for _, sceneKey in ipairs(sceneOrder) do
		local scene = self._plan.scenes[sceneKey]
		local componentByInstanceId = {}
		local lifecycleList = {}

		-- Step 1: construct every instance via new(config).
		local order = scene.lifecycle_order or {}
		-- Fallback: instance array order if no lifecycle_order.
		if #order == 0 then
			for _, inst in ipairs(scene.instances or {}) do
				table.insert(order, inst.instance_id)
			end
		end
		local byInstanceId = {}
		for _, inst in ipairs(scene.instances or {}) do
			byInstanceId[inst.instance_id] = inst
		end
		for _, instId in ipairs(order) do
			local inst = byInstanceId[instId]
			if inst and includeScriptId[inst.script_id] then
				local goInst = self._services.workspaceFind(inst.game_object_id)
				local comp = self:_buildComponent(
					inst.script_id, goInst, inst.game_object_id,
					(goInst and goInst.Name) or "", inst.config or {},
					"scene", sceneKey)
				if comp then
					componentByInstanceId[instId] = comp
					table.insert(lifecycleList, comp)
					-- Honor planner-supplied active/enabled.
					local m = self._meta[comp]
					m.activeSelf = inst.active ~= false
					m.enabled = inst.enabled ~= false
				end
			end
		end

		-- Step 2: inject host surface + references (cycle-safe because
		-- step 1 touched no peers per the constructor-purity rule).
		for _, comp in ipairs(lifecycleList) do
			local m = self._meta[comp]
			self:_injectHostSurface(comp,
				self._services.workspaceFind(m.gameObjectId), m.gameObjectId)
		end
		self:_wireReferences(scene.references or {}, componentByInstanceId,
			crossDomainEdges)

		-- Steps 3-5: Awake -> OnEnable -> Start.
		self:_runAwakeEnableStart(lifecycleList)
	end

	-- Step 6: update loops via heartbeat + fixed-step accumulator.
	if self._services.heartbeat then
		local engine = self
		self._heartbeatConn = self._services.heartbeat:Connect(function(dt)
			engine:_tick(dt)
		end)
	end

	self._crossDomainEdges = crossDomainEdges
	return crossDomainEdges
end

function SceneRuntime:_tick(dt)
	-- Update + LateUpdate every frame; FixedUpdate via fixed-step.
	for comp, m in pairs(self._meta) do
		if m.activeSelf and m.enabled then
			self:_callMethod(comp, "Update", dt)
		end
	end
	self._fixedAccum = self._fixedAccum + dt
	while self._fixedAccum >= self._fixedStep do
		self._fixedAccum = self._fixedAccum - self._fixedStep
		for comp, m in pairs(self._meta) do
			if m.activeSelf and m.enabled then
				self:_callMethod(comp, "FixedUpdate", self._fixedStep)
			end
		end
	end
	for comp, m in pairs(self._meta) do
		if m.activeSelf and m.enabled then
			self:_callMethod(comp, "LateUpdate", dt)
		end
	end
end

-- ---------------------------------------------------------------------
-- Cross-domain edge report (consumed by write_output)
-- ---------------------------------------------------------------------

function SceneRuntime:crossDomainEdges()
	return self._crossDomainEdges or {}
end

return SceneRuntime
